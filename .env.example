# Vera backend configuration — copy to .env and fill in what you run.
#
# EVERYTHING here is optional by design: an unset integration switches that capability
# off and Vera degrades gracefully (the startup log prints a config report showing
# exactly what's wired). URLs can point anywhere — one box or ten, it's all just HTTP.
#
# Naming convention: service endpoints are *_BASE, credentials are *_KEY. Pre-convention
# names (SEARXNG_URL, HOME_ASSISTANT_TOKEN, GROCY_API_KEY, …) still work this release —
# the config report flags any deprecated name in use with its replacement.

# ── Core LLM endpoints ─────────────────────────────────────────────────────────────
# Main assistant model — any OpenAI-compatible /v1 (llama.cpp, llama-swap, vLLM, Ollama…).
VERA_BASE=
VERA_MODEL=
# Server-specific chat-template options as a JSON object (e.g. the Qwen3 hybrid-thinking
# toggle on llama.cpp/vLLM: {"enable_thinking": false}). Leave empty for strict OpenAI
# endpoints — the field is omitted from requests entirely.
VERA_CHAT_TEMPLATE_KWARGS=
# Heavier "dream/coder" model for nightly consolidation + the coding agent (optional).
DREAM_BASE=
DREAM_MODEL=
# Tool-call transport for the coder agent: openai (standard tool_calls; default) or mlx —
# set to mlx when serving via mlx_lm.server, which doesn't emit OpenAI tool_calls.
DREAM_TOOL_PROTOCOL=
# Optional hooks bracketing Pulse's batched end-of-run claim audit, for deployments that
# serve the audit model on demand: the run POSTs the wake URL before auditing (cold model
# load is fine; one load covers every card in the run) and the release URL after. A wake
# reply of {"already_up": true} tells the run the model is not its to release. Leave both
# empty when the audit endpoint is always resident (or absent).
AUDIT_WAKE_URL=
AUDIT_RELEASE_URL=
# Image-generation service for Pulse cover art (optional). The contract is the standard
# OpenAI Images API (POST {base}/v1/images/generations) — any compatible endpoint works,
# including services/vera-image. IMAGE_PROTOCOL=vera keeps the bespoke reference contract
# (deterministic seeds + the vision pause/resume extension).
VERA_IMAGE_BASE=
IMAGE_PROTOCOL=

# ── Conversation ingestion (Profile Graph) ────────────────────────────────────────
# The extraction job learns from how you actually talk. CONVERSATION_DUMP_DIR is a watched
# folder for ChatGPT and Claude.ai data exports (drop the export JSON in and it gets ingested
# on the next run). Optional; skipped when unset. Vera's own Open WebUI chats are ingested
# from OWUI directly. Coding-agent transcripts are intentionally never a source.
CONVERSATION_DUMP_DIR=

# ── Embeddings ─────────────────────────────────────────────────────────────────────
# OpenAI-compatible /v1/embeddings endpoint for the Profile Graph's dedup + novelty math.
# Optional: unset, the graph degrades to an LLM canonicalization tie-break. No LAN default.
VERA_EMBED_URL=
VERA_EMBED_MODEL=
# Profile Graph tuning (declared constants; defaults are sensible, override only to calibrate).
# DECAY is per-day engagement attenuation (~23-day half-life); DEDUP_SAME/NEW are the cosine
# collapse/new thresholds; DAMPING/MAX_HOPS shape spreading-activation relevance.
#PROFILE_GRAPH_DECAY=0.97
#PROFILE_GRAPH_BONUS=1.0
#PROFILE_GRAPH_DEDUP_SAME=0.90
#PROFILE_GRAPH_DEDUP_NEW=0.78
#PROFILE_GRAPH_DAMPING=0.5
#PROFILE_GRAPH_MAX_HOPS=2
# Set to 1 once the conversation-extraction job is live: the legacy interest stores
# (vera_interests, user_profile) stop accruing so the graph is the sole interest write target.
# Reversible; reads and cooldown/persona bookkeeping are unaffected. Engage it together with
# deploying the extraction job, so old writes stop and graph writes start in the same step.
#PROFILE_GRAPH_CUTOVER=

# ── Scout (Pulse candidate search) ─────────────────────────────────────────────────
# The Scout fans cheap searches across sources over the graph's live nodes. news/local
# ride the SEARXNG_BASE web search; weather rides WEATHER_LAT/LON; github/papers default
# to the public endpoints below. An unconfigured source is skipped and surfaced, never
# fabricated.
#GITHUB_API_BASE=https://api.github.com
#ARXIV_BASE=http://export.arxiv.org
# Reddit is a gated plugin (register a "script" app at reddit.com/prefs/apps). Set the creds
# here or in the app's plugin store; unset, the Reddit source stays off.
#REDDIT_CLIENT_ID=
#REDDIT_CLIENT_SECRET=
#REDDIT_USER_AGENT=vera-scout/1.0 (by /u/you)
# Selection + breadth knobs: ENGAGEMENT_FLOOR is the decayed-engagement bar for an interest
# to count live; MAX_NODES caps nodes scouted per run; EXCLUDED_TYPES is a CSV of node types
# never scouted (people are conversation context, not searchable topics); the *_MAX cap
# results per source.
#SCOUT_ENGAGEMENT_FLOOR=0.5
#SCOUT_MAX_NODES=12
#SCOUT_EXCLUDED_TYPES=person
#SCOUT_NEWS_MAX=6
#SCOUT_REDDIT_MAX=6
#SCOUT_GITHUB_MAX=6
#SCOUT_PAPERS_MAX=6

# ── Pulse ranking (Analyst) ────────────────────────────────────────────────────────
# The Analyst scores every Scout candidate with one weighted sum of five terms, all math:
#   score = 0.35*relevance + 0.25*novelty + 0.20*opportunity + 0.15*urgency + 0.05*serendipity
# Weights and thresholds are declared constants (the audit surface); override only to calibrate.
#PULSE_W_RELEVANCE=0.35
#PULSE_W_NOVELTY=0.25
#PULSE_W_OPPORTUNITY=0.20
#PULSE_W_URGENCY=0.15
#PULSE_W_SERENDIPITY=0.05
# NOVELTY_FLOOR drops a finding too similar to a recent card before the classifier runs.
# URGENCY_DECAY is the per-day decay of a past event's urgency; URGENCY_WINDOW (days) sets how
# near a deadline scores ~1.0; UNDATED_URGENCY is the baseline for dateless findings.
# EPSILON is the exploration share reserved for an adjacent-node serendipity pick.
#PULSE_NOVELTY_FLOOR=0.10
#PULSE_URGENCY_DECAY=0.85
#PULSE_URGENCY_WINDOW=7.0
#PULSE_UNDATED_URGENCY=0.10
#PULSE_EPSILON=0.1
# Per-run ranking log (every term for every candidate) for weight calibration.
#ANALYST_LOG_PATH=/data/analyst_log.jsonl
# Editor (synthesis stage): STALE_CLAIM_DAYS is how old a source can be before it fails a
# present-state claim in the date-aware audit; LINK_ENGAGEMENT_FLOOR / LINK_LIMIT bound the
# active graph neighbours offered to cross-domain synthesis.
#PULSE_STALE_CLAIM_DAYS=120
#PULSE_LINK_ENGAGEMENT_FLOOR=0.5
#PULSE_LINK_LIMIT=4
#JOURNAL_ENGAGEMENT_FLOOR=0.5

# ── Pulse feedback loop (write-back + learned weights) ──────────────────────────────
# Each reaction on a card moves the served node's engagement: thumb up adds UP_BONUS (and
# reinforces traversed edges by EDGE_REINFORCE), thumb down multiplies by DOWN_DECAY,
# open/bookmark add their bonus, an expired card multiplies by EXPIRE_PENALTY, and a topic
# returning in chat adds DISCUSSED_BONUS. The weekly fit learns the five ranking weights from
# these outcomes once FIT_MIN_SAMPLES labeled cards accrue (below it, the hand-set weights stand).
#PULSE_UP_BONUS=2.0
#PULSE_DOWN_DECAY=0.5
#PULSE_OPEN_BONUS=1.0
#PULSE_BOOKMARK_BONUS=1.5
#PULSE_EXPIRE_PENALTY=0.9
#PULSE_DISCUSSED_BONUS=3.0
#PULSE_EDGE_REINFORCE=0.5
#PULSE_FIT_MIN_SAMPLES=200
#PULSE_FIT_ITERS=800
#PULSE_FIT_LR=0.5
#LEARN_DB_PATH=/data/learn/store.db

# ── Open WebUI ─────────────────────────────────────────────────────────────────────
# The chat front-end. Vera uses it for memory, chat promotion, and self-authored skills.
OWUI_BASE=
OWUI_KEY=
# Pulse: OWUI folder id for promoted cards + your OWUI user UUID for user-scoped feeds.
PULSE_FOLDER_ID=
VERA_DEFAULT_USER=

# ── Web search ─────────────────────────────────────────────────────────────────────
# SearXNG /search endpoint (powers research, Pulse, signals news).
SEARXNG_BASE=
# Playwright run-server websocket for full-page renders (optional; snippets-only without it).
PLAYWRIGHT_WS=

# ── Identity & location ────────────────────────────────────────────────────────────
# Your name (Vera's prompts address you by it) and the home area's display name.
VERA_OWNER_NAME=
HOME_LOCATION_NAME=
# IANA timezone for schedules and day boundaries (UTC when unset).
HOME_TZ=
# Home coordinates — weather + nearby-signals veins report unconfigured without them.
WEATHER_LAT=
WEATHER_LON=
# Two-letter US state for FEMA disaster declarations (optional; also marks the home as US).
HOME_STATE=
# fahrenheit (default) or celsius — forecasts, thresholds, and labels all follow it.
TEMPERATURE_UNIT=

# ── Integrations (Home Assistant / Grocy / Mealie / Overseerr / Unraid / SearXNG) ──
# All of these are runtime plugins: set them here for headless installs (env-set values
# are locked against runtime edits), or leave them empty and configure them live through
# the integrations API / the app's plugin store. Configured-by-env means enabled.

# ── Home Assistant ─────────────────────────────────────────────────────────────────
# Use an IP, not .local — containers on a bridge network can't resolve mDNS.
HOME_ASSISTANT_BASE=
HOME_ASSISTANT_KEY=
# Whole-house event capture + behavior model: EXPERIMENTAL, always off until you enable
# the home_modeling feature through the integrations API (requires an explicit ack of its
# ramifications). HOME_EVENTS_ENABLED=false survives only as a hard kill-switch.
HOME_EVENTS_IGNORE=
HOME_EVENTS_RETAIN_DAYS=30
HOME_MODEL_WINDOW_DAYS=30
# Map reconciliation (durable facts vs live HA).
RECONCILE_STALE_DAYS=180
RECONCILE_REMOVAL_RUNS=3
# Live-source index seeds: JSON array inline, or a file path (e.g. /data/live_sources.json).
HOME_LIVE_SOURCE_INDEX=
HOME_LIVE_SOURCE_INDEX_PATH=

# ── Kitchen ────────────────────────────────────────────────────────────────────────
GROCY_BASE=
GROCY_KEY=
MEALIE_BASE=
MEALIE_KEY=
# Grocy shopping list id that Vera's writes target (Grocy's default list is 1).
GROCY_SHOPPING_LIST_ID=1
# Mealie categories that are orthogonal axes, not cuisines (apply alongside a cuisine) —
# ';'-separated, each "Name" or "Name=hint telling the classifier when it applies".
# e.g. MEALIE_ORTHOGONAL_CATEGORIES=Preserving=shelf-stable preservation recipes
MEALIE_ORTHOGONAL_CATEGORIES=

# ── Media ──────────────────────────────────────────────────────────────────────────
OVERSEERR_BASE=
OVERSEERR_KEY=
# Weekly curation digest: EXPERIMENTAL, off until enabled (with ack) via the integrations
# API under overseerr. MEDIA_CURATION_ENABLED=false survives only as a hard kill-switch.
MEDIA_CURATION_CAP=8
# Your household's taste profile for the curator — hard rules, exclusions, language
# preferences, one line. Empty = neutral (good collection, popularity is a pool not a ranking).
MEDIA_CURATION_TASTE=
# Pool shaping (defaults shown): candidates handed to the model / per discover type /
# the zeitgeist web-search query and its result/page counts.
MEDIA_CURATION_POOL_MAX=60
MEDIA_CURATION_DISCOVER_LIMIT=20
MEDIA_CURATION_ZEITGEIST_QUERY=
MEDIA_CURATION_ZEITGEIST_RESULTS=6
MEDIA_CURATION_ZEITGEIST_PAGES=3

# ── Apple Reminders ────────────────────────────────────────────────────────────────
# URL of the vera-reminders EventKit bridge (services/vera-reminders), which runs on a
# Mac signed into the iCloud account whose lists Vera should see — shared lists included.
VERA_REMINDERS_URL=

# ── Signals (external watch vein) ──────────────────────────────────────────────────
# What the vein watches FOR — all judgment knobs, no code edits:
# The bar an event must clear, completing "would plausibly …" in the news/watch judges.
# Empty = "change what a reasonable household should know or do this week".
SIGNALS_ORIENTATION=
# News beats the qualitative sentinel sweeps, ';'-separated (defaults are region-neutral:
# supply chains / disasters / geopolitics).
SIGNALS_NEWS_QUERIES=
# Which collectors run, comma-separated (usgs,gdacs,fema,federal_register,treasury,vix,
# fred_hy,eia_grid). Empty = auto: global sources always; the keyless US-centric set (fema,
# federal_register, treasury, vix) only when HOME_STATE/coordinates say US; key-gated
# sources only when their keys are set.
SIGNALS_SENTINELS=
# Add the grounded "Affected goods" line to supply/geopolitical cards (off by default).
SIGNALS_IMPACT_GOODS=false
# Watch topics treated as numeric (a material % move counts as change), comma-separated.
SIGNALS_NUMERIC_KEYWORDS=price,cost,rate,spread,yield,index,inflation
# Optional API keys — collectors skip cleanly when absent.
FRED_KEY=
EIA_KEY=
# Your grid's balancing authority (e.g. MISO, PJM, ERCO) for demand-stress monitoring.
EIA_RESPONDENT=
SIGNALS_NEAR_KM=600
# Trip thresholds (tuned defaults; raise/lower to taste).
SIGNALS_QUAKE_GLOBAL_MIN=7.0
SIGNALS_QUAKE_NEAR_MIN=5.0
SIGNALS_YIELD_INVERSION_PCT=-0.40
SIGNALS_VIX_REGIME=30.0
SIGNALS_HY_SPREAD_PCT=8.0
SIGNALS_ECON_CRITICAL_FACTORS=2
SIGNALS_GRID_DEV_NOTICE=5.0
SIGNALS_GRID_DEV_ALERT=8.0
SIGNALS_NEWS_MIN_SEVERITY=4

# ── Weather ────────────────────────────────────────────────────────────────────────
# "Full forecast" link template for weather cards, with {lat}/{lon} placeholders
# (e.g. https://www.windy.com/{lat}/{lon}). Empty = NWS link for US homes, none elsewhere.
WEATHER_FORECAST_URL=

# ── Actuation ──────────────────────────────────────────────────────────────────────
# The ha.service allowlist (confirm-gated physical actuation): exact domain.service grants,
# plus whole domains where any service is fine. Defaults shown.
HA_ALLOWED_SERVICES=climate.set_temperature,scene.turn_on,script.turn_on,update.install
HA_ALLOWED_DOMAINS=light,switch,media_player
# Unraid hosts only:
UNRAID_BASE=
UNRAID_KEY=
# Host update-status JSON mounted read-only into the container (for the updates check).
UNRAID_UPDATE_STATUS_PATH=

# ── Health checks ──────────────────────────────────────────────────────────────────
# Endpoints above are probed automatically when set. Extra TCP liveness watches:
# "name=host:port,name2=host2:port2" (e.g. a barcode-scanner Pi).
HEALTH_TCP_WATCHES=

# ── Scheduler (built-in; runs all recurring jobs) ──────────────────────────────────
SCHEDULER_ENABLED=true
# Per-job overrides — cron expression + enable switch, e.g.:
#   SCHEDULE_PULSE="0 5 * * *"          SCHEDULE_PULSE_ENABLED=true
#   SCHEDULE_WEATHER="0 */6 * * *"      SCHEDULE_SIGNALS="0 6,18 * * *"
#   SCHEDULE_MEMORY_GROOM="0 4 * * *"   SCHEDULE_HOME_MODEL="30 3 * * *"
#   SCHEDULE_HOME_RECONCILE="0 3 * * *" SCHEDULE_HEARTBEAT="*/20 * * * *"
#   SCHEDULE_HEALTHCHECK="*/15 * * * *" SCHEDULE_UPDATES="30 7 * * *"
#   SCHEDULE_MEDIA_CURATE="0 9 * * 0"
# Consecutive failures before a job earns a System-vein card (cleared on recovery).
#SCHEDULER_FAIL_CARD_AFTER=3
HEARTBEAT_ENABLED=true
# Binary-sensor device classes the heartbeat surfaces as "Open/active" (defaults shown).
HEARTBEAT_ALERT_CLASSES=door,window,garage_door,opening,moisture,smoke,gas,carbon_monoxide
# Journal: how many due commitments a single heartbeat tick acts on (spreads the load).
#JOURNAL_DUE_CAP=3
# Nightly grooming kill switches (the unified digest's two passes).
KNOWLEDGE_GROOM_ENABLED=true
MEMORY_GROOM_ENABLED=true

# ── Inner-life tunables (sane defaults) ────────────────────────────────────────────
KNOWLEDGE_AGENT_TOKEN=
DREAM_DEDUP_THRESHOLD=0.84
DREAM_PROMOTE_CONF=0.6
DREAM_CLUSTER_THRESHOLD=0.5
DREAM_MAX_OPINIONS=3
VERA_MEMORY_CORE_CHARS=4000
VERA_MEMORY_SCRATCH_TTL_HOURS=48
VERA_INTEREST_COOLDOWN_HOURS=72
# A Pulse run row stuck in 'running' longer than this (seconds) is treated as dead.
PULSE_RUN_STALE_SECS=1800
# Each Pulse run delivers between MIN and MAX novel cards, re-triaging up to ROUNDS
# times when the dedup gate kills proposals (the gate itself never loosens).
PULSE_MIN_CARDS=2
PULSE_MAX_CARDS=8
PULSE_TRIAGE_ROUNDS=3
# Variety guarantee: at most this many research cards per standing interest per run.
PULSE_MAX_PER_INTEREST=1

# ── Storage (defaults under the /data volume; rarely need changing) ────────────────
#PULSE_DB_PATH=/data/pulse.db
#KNOWLEDGE_DB_PATH=/data/knowledge.db
#SCHEDULER_DB_PATH=/data/scheduler.db
#INTEGRATIONS_PATH=/data/integrations.json
#VEINS_PATH=/data/veins.json
#VERA_MEMORY_DIR=/data/vera_memory
#HOME_EVENTS_DB_PATH=/data/home_events.db
#HOME_MODEL_DB_PATH=/data/home_model.db
#HOME_RECONCILE_DB_PATH=/data/home_reconcile.db
#HEARTBEAT_DB_PATH=/data/heartbeat.db
#ACTION_DB_PATH=/data/actions.db
#AUTHORING_DB_PATH=/data/authoring.db
#GROOM_DB_PATH=/data/groom.db
#MEDIA_DB_PATH=/data/media.db
#RHYTHM_DB_PATH=/data/rhythm.db
#USER_PROFILE_DB_PATH=/data/user_profiles/store.db
#VERA_INTERESTS_DB_PATH=/data/vera_interests/store.db
#PROFILE_GRAPH_DB_PATH=/data/profile_graph/store.db
#EXTRACT_DB_PATH=/data/extract/cursors.db
#VERA_JOURNAL_PATH=/data/journal/JOURNAL.md
#FEEDBACK_PATH=/data/feedback.jsonl
#SIGNALS_LOG_PATH=/data/signals_log.jsonl

# ── Companion services (run on their own hosts, not in this container) ─────────────
# These are read by the reference voice/image services where THEY run; they're listed
# here so the whole stack's config surface is discoverable in one file. Host-side
# scripts (backup, offsite, rag-sync, sandbox) document their own env in their headers.

# vera-voice (services/vera-voice — batch HTTP :8131, Wyoming ASR :10300 / TTS :10200)
#VERA_STT_ENGINE=parakeet                                # parakeet | whisper (Wyoming ASR)
#VERA_STT_MODEL=mlx-community/whisper-small-mlx          # batch-path Whisper model
#VERA_PARAKEET_MODEL=mlx-community/parakeet-tdt-0.6b-v2
#VERA_TTS_MODEL=prince-canuma/Kokoro-82M
#VERA_TTS_VOICE=af_heart
#VERA_TTS_LANG=a                                         # Kokoro language code
#VERA_ASR_PORT=10300
#VERA_TTS_PORT=10200
#VERA_WARM=1                                             # preload models at start
#VERA_FFMPEG=                                            # explicit ffmpeg path (auto-detected when unset)
#VERA_ATTRIBUTION_URL=                                   # shown by Wyoming clients (defaults to the Vera repo)

# vera-reminders (services/vera-reminders — Apple Reminders EventKit bridge :8132)
#VERA_REMINDERS_HOST=0.0.0.0
#VERA_REMINDERS_PORT=8132

# vera-image (services/vera-image — image gen + on-demand vision/coder handoff)
#VERA_IMAGE_MODEL_PATH=~/models/qwen-image-8bit
#VERA_MFLUX_BIN=~/venvs/vera/bin/mflux-generate-qwen
#VERA_VISION_LABEL=com.vera.vision                       # launchd label paused during generation
#VERA_CODER_SCRIPT=~/.vera/vera-coder.sh

# Host scripts that talk to Open WebUI directly (rag-ingest):
#OWUI_EMAIL=
#OWUI_PASSWORD=
# Offline-reference root synced into OWUI knowledge (rag-sync; example-deployment value):
#REFERENCE_ROOT=/mnt/user/reference
